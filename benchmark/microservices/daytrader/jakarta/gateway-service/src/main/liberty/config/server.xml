<?xml version="1.0" encoding="UTF-8"?>
<server description="DayTrader Gateway Service">
    <featureManager>
        <feature>restfulWS-3.1</feature>
        <feature>cdi-4.0</feature>
        <feature>jsonb-3.0</feature>
        <feature>jsonp-2.1</feature>
        <feature>mpConfig-3.1</feature>
        <feature>mpHealth-4.0</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint" httpPort="${default.http.port}" host="*" />

    <webApplication location="gateway-service.war" contextRoot="/" />
</server>
