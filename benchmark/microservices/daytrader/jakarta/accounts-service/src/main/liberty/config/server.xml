<?xml version="1.0" encoding="UTF-8"?>
<server description="DayTrader Accounts Service">
    <featureManager>
        <feature>restfulWS-3.1</feature>
        <feature>cdi-4.0</feature>
        <feature>jsonb-3.0</feature>
        <feature>jsonp-2.1</feature>
        <feature>mpConfig-3.1</feature>
        <feature>mpHealth-4.0</feature>
        <feature>jdbc-4.3</feature>
        <feature>jndi-1.0</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint" httpPort="${default.http.port}" host="*" />

    <webApplication location="accounts-service.war" contextRoot="/" />

    <library id="derbyLib">
        <fileset dir="${shared.resource.dir}" includes="derby*.jar" />
    </library>

    <dataSource id="AccountsDataSource" jndiName="jdbc/AccountsDataSource">
        <jdbcDriver libraryRef="derbyLib" />
        <properties.derby.embedded databaseName="${server.output.dir}/tradesdb" createDatabase="create" />
    </dataSource>
</server>
